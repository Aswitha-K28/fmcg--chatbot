        },
        "year": {
          "type": "INT",
          "description": "Year of promotion"
        }
      },
      "keywords": [
        "price",
        "pricing",
        "promo",
        "promotion",
        "discount",
        "offer",
        "deal",
        "mrp",
        "base price",
        "festival offer",
        "seasonal",
