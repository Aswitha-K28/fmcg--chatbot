{
  "database": "fmcg_db",
  "description": "FMCG company database covering sales, products, brands, distribution, marketing and supply chain across India",
  "tables": {
    "companies": {
      "description": "Parent companies that own multiple brands",
      "columns": {
        "company_id": {
          "type": "VARCHAR",
          "description": "Unique company identifier"
        },
        "company_name": {
          "type": "VARCHAR",
          "description": "Name of the company e.g. HUL, ITC, Nestle, P&G"
        },
        "hq_city": {
          "type": "VARCHAR",
          "description": "Headquarters city"
        },
        "founded_year": {
          "type": "INT",
          "description": "Year company was founded"
        },
        "revenue_cr": {
          "type": "DECIMAL",
          "description": "Annual revenue in crores"
        }
      },
      "keywords": [
        "company",
        "parent company",
        "conglomerate",
        "hul",
        "itc",
        "nestle",
        "pg",
        "dabur",
        "marico",
        "godrej",
        "britannia"
      ]
    },
    "brands": {
      "description": "Individual brands owned by companies. Each brand belongs to one company",
      "columns": {
        "brand_id": {
          "type": "VARCHAR",
          "description": "Unique brand identifier"
        },
        "brand_name": {
          "type": "VARCHAR",
          "description": "Brand name e.g. Surf Excel, Dove, Maggi, Lux"
        },
        "company_id": {
          "type": "VARCHAR",
          "description": "Foreign key to companies table"
        },
        "company_name": {
          "type": "VARCHAR",
          "description": "Denormalized company name for quick access"
        },
        "launch_year": {
          "type": "INT",
          "description": "Year brand was launched in India"
        }
      },
      "keywords": [
        "brand",
        "brands",
        "label",
        "surf excel",
        "dove",
        "lux",
        "maggi",
        "ariel",
        "pantene",
        "good day",
        "bourbon"
      ]
    },
    "categories": {
      "description": "Product categories like Detergent, Personal Care, Food, Beverages",
      "columns": {
        "category_id": {
          "type": "VARCHAR",
          "description": "Unique category identifier"
        },
        "category_name": {
          "type": "VARCHAR",
          "description": "Category name e.g. Detergent, Personal Care, Food, Beverages, Snacks"
        }
      },
      "keywords": [
        "category",
        "categories",
        "segment",
        "type",
        "detergent",
        "personal care",
        "food",
        "beverages",
        "snacks",
        "health",
        "home care"
      ]
    },
    "subcategories": {
      "description": "Sub-level classification under categories",
      "columns": {
        "subcategory_id": {
          "type": "VARCHAR",
          "description": "Unique subcategory identifier"
        },
        "category_id": {
          "type": "VARCHAR",
          "description": "Foreign key to categories"
        },
        "subcategory_name": {
          "type": "VARCHAR",
          "description": "Sub-category name e.g. Fabric Whitener, Shampoo, Noodles"
        }
      },
      "keywords": [
        "subcategory",
        "sub category",
        "sub-category",
        "fabric whitener",
        "shampoo",
        "noodles",
        "biscuits",
        "soap",
        "toothpaste"
      ]
    },
    "products": {
      "description": "Individual SKUs (Stock Keeping Units). Each product belongs to a brand and category",
      "columns": {
        "product_id": {
          "type": "VARCHAR",
          "description": "Unique product/SKU identifier"
        },
        "brand_id": {
          "type": "VARCHAR",
          "description": "Foreign key to brands"
        },
        "category_id": {
          "type": "VARCHAR",
          "description": "Foreign key to categories"
        },
        "subcategory_id": {
          "type": "VARCHAR",
          "description": "Foreign key to subcategories"
        },
        "sku_name": {
          "type": "VARCHAR",
          "description": "Full product name e.g. Surf Excel 500g, Maggi 200g"
        },
        "weight_variant": {
          "type": "VARCHAR",
          "description": "Size or weight variant e.g. 100g, 500g, 1kg, 200ml"
        },
        "mrp": {
          "type": "DECIMAL",
          "description": "Maximum Retail Price in INR"
        },
        "cost_price": {
          "type": "DECIMAL",
          "description": "Manufacturing cost per unit in INR"
        }
      },
      "keywords": [
        "product",
        "products",
        "sku",
        "item",
        "variant",
        "size",
        "weight",
        "mrp",
        "price",
        "cost"
      ]
    },
    "zones": {
      "description": "Top level geographic division. India divided into 4 zones",
      "columns": {
        "zone_id": {
          "type": "VARCHAR",
          "description": "Unique zone identifier"
        },
        "zone_name": {
          "type": "VARCHAR",
          "description": "Zone name: North, South, East, West"
        }
      },
      "keywords": [
        "zone",
        "zones",
        "north",
        "south",
        "east",
        "west",
        "region",
        "geography",
        "area"
      ]
    },
    "regions": {
      "description": "Cities and states within zones. Each region belongs to one zone",
      "columns": {
        "region_id": {
          "type": "VARCHAR",
          "description": "Unique region identifier"
        },
        "zone_id": {
          "type": "VARCHAR",
          "description": "Foreign key to zones"
        },
        "zone_name": {
          "type": "VARCHAR",
          "description": "Denormalized zone name"
        },
        "region_name": {
          "type": "VARCHAR",
          "description": "City or state name e.g. Mumbai, Delhi, Bangalore, Chennai"
        }
      },
      "keywords": [
        "region",
        "city",
        "state",
        "location",
        "mumbai",
        "delhi",
        "bangalore",
        "chennai",
        "kolkata",
        "hyderabad",
        "pune",
        "ahmedabad"
      ]
    },
    "distributors": {
      "description": "Wholesale distributors who supply products to outlets in specific regions",
      "columns": {
        "distributor_id": {
          "type": "VARCHAR",
          "description": "Unique distributor identifier"
        },
        "region_id": {
          "type": "VARCHAR",
          "description": "Foreign key to regions"
        },
        "distributor_name": {
          "type": "VARCHAR",
          "description": "Name of the distributor"
        },
        "credit_limit": {
          "type": "DECIMAL",
          "description": "Credit limit extended to distributor in INR"
        },
        "payment_terms": {
          "type": "VARCHAR",
          "description": "Payment terms e.g. Net30, Net45"
        },
        "is_active": {
          "type": "BOOLEAN",
          "description": "Whether distributor is currently active"
        }
      },
      "keywords": [
        "distributor",
        "distributors",
        "wholesale",
        "supply chain",
        "dealer",
        "credit",
        "payment terms"
      ]
    },
    "outlets": {
      "description": "Retail outlets where products are sold to end consumers",
      "columns": {
        "outlet_id": {
          "type": "VARCHAR",
          "description": "Unique outlet identifier"
        },
        "region_id": {
          "type": "VARCHAR",
          "description": "Foreign key to regions"
        },
        "distributor_id": {
          "type": "VARCHAR",
          "description": "Foreign key to distributors"
        },
        "outlet_name": {
          "type": "VARCHAR",
          "description": "Name of the outlet"
        },
        "outlet_type": {
          "type": "VARCHAR",
          "description": "Type: Kirana, Supermarket, Hypermarket, Pharmacy, Online"
        },
        "monthly_footfall": {
          "type": "INT",
          "description": "Average monthly customer visits"
        },
        "shelf_space_sqft": {
          "type": "DECIMAL",
          "description": "Shelf space allocated in square feet"
        },
        "is_active": {
          "type": "BOOLEAN",
          "description": "Whether outlet is active"
        }
      },
      "keywords": [
        "outlet",
        "store",
        "shop",
        "retail",
        "kirana",
        "supermarket",
        "hypermarket",
        "pharmacy",
        "footfall",
        "shelf space"
      ]
    },
    "sales": {
      "description": "Transaction level sales data. Core fact table linking products, regions, channels and time",
      "columns": {
        "sale_id": {
          "type": "VARCHAR",
          "description": "Unique sale identifier"
        },
        "product_id": {
          "type": "VARCHAR",
          "description": "Foreign key to products"
        },
        "distributor_id": {
          "type": "VARCHAR",
          "description": "Foreign key to distributors \u2014 use this to JOIN distributors"
        },
        "region_id": {
          "type": "VARCHAR",
          "description": "Foreign key to regions"
        },
        "zone_id": {
          "type": "VARCHAR",
          "description": "Foreign key to zones"
        },
        "zone_name": {
          "type": "VARCHAR",
          "description": "Denormalized zone name e.g. South, West, North, East"
        },
        "region_name": {
          "type": "VARCHAR",
          "description": "Denormalized region name e.g. Hyderabad, Mumbai, Delhi"
        },
        "sku_name": {
          "type": "VARCHAR",
          "description": "Product SKU name"
        },
        "brand_name": {
          "type": "VARCHAR",
          "description": "Denormalized brand name e.g. Dove, Maggi, Ariel"
        },
        "channel": {
          "type": "VARCHAR",
          "description": "Sales channel"
        },
        "units_sold": {
          "type": "INT",
          "description": "Number of units sold"
        },
        "mrp": {
          "type": "DECIMAL",
          "description": "Maximum retail price"
        },
        "discount_pct": {
          "type": "DECIMAL",
          "description": "Discount percentage"
        },
        "revenue": {
          "type": "DECIMAL",
          "description": "Revenue generated"
        },
        "cogs": {
          "type": "DECIMAL",
          "description": "Cost of goods sold"
        },
        "quarter": {
          "type": "VARCHAR",
          "description": "Quarter e.g. Q1, Q2, Q3, Q4"
        },
        "year": {
          "type": "INT",
          "description": "Year e.g. 2023, 2024"
        },
        "sale_date": {
          "type": "DATE",
          "description": "Date of sale"
        }
      },
      "keywords": [
        "sales",
        "revenue",
        "sold",
        "units",
        "transactions",
        "performance",
        "top selling",
        "best selling",
        "total sales",
        "how much sold",
        "channel",
        "trade"
      ]
    },
    "inventory": {
      "description": "Current stock levels per product per warehouse",
      "columns": {
        "inventory_id": {
          "type": "VARCHAR",
          "description": "Unique inventory record identifier"
        },
        "product_id": {
          "type": "VARCHAR",
          "description": "Foreign key to products"
        },
        "warehouse": {
          "type": "VARCHAR",
          "description": "Warehouse location name"
        },
        "stock_quantity": {
          "type": "INT",
          "description": "Current quantity in stock"
        },
        "reorder_level": {
          "type": "INT",
          "description": "Minimum stock level before reorder is triggered"
        },
        "days_of_stock": {
          "type": "INT",
          "description": "Number of days current stock will last at current sales rate"
        },
        "last_restocked": {
          "type": "DATE",
          "description": "Date of last restocking"
        },
        "is_stockout": {
          "type": "BOOLEAN",
          "description": "True if product is currently out of stock"
        }
      },
      "keywords": [
        "inventory",
        "stock",
        "stockout",
        "out of stock",
        "reorder",
        "warehouse",
        "days of stock",
        "replenishment",
        "available",
        "shortage"
      ]
    },
