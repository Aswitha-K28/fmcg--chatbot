# FMCG BI Chatbot — System Architecture

## Full Architecture Diagram

```mermaid
flowchart TD
    User(["👤 User\nbrowser"])

    subgraph Frontend ["⚛️ React Frontend  (port 3000)"]
        UI["Chat UI\ntalk2data/src/App.js"]
        Hook["useChat.js\n(Redux state manager)"]
        SSEService["backendService.js\n(SSE stream reader)"]
        Store["chatSlice.js\n(Redux store:\nmessages / thinkingSteps)"]
    end

    subgraph Backend ["🐍 backend_server.py  (FastAPI · port 8002)"]
        FastAPI["POST /chat\n(StreamingResponse SSE)"]
        ThinkingHandler["StreamThinkingHandler\non_tool_start → isNew:true\non_tool_end  → isNew:false"]
        Agent["Supervisor Agent\n(LangChain · llama-3.3-70b)"]
    end

    subgraph MCP ["🔧 mcp_server.py  (FastAPI · port 8000)"]
        IntentEP["POST /tools/extract_intent\nLLM → JSON intent + entities\n(llama-3.1-8b-instant)"]
        SearchEP["POST /tools/schematic_search\nIntent → Parallel Search → RRF Fusion"]
        MalloyGenEP["POST /tools/generate_malloy\nIntent + Schema → Malloy DSL\n(llama-3.3-70b)"]

        subgraph SearchService ["services/search_service.py"]
            BM25["BM25 Search\n(keyword exact match)"]
            FAISS["FAISS Search\n(semantic / vector)"]
            N2V["Node2Vec Search\n(Neo4j graph traversal)"]
            RRF["RRF Fusion\n(ranked table list)"]
        end
    end

    subgraph Tools ["🛠️ LangChain Tools  (tools/)"]
        T1["intent_entity_tool.py\n→ calls /extract_intent"]
        T2["search_tool.py\n→ calls /schematic_search"]
        T3["malloy_generator_tool.py\n→ calls /generate_malloy"]
        T4["malloy_executor_tool.py\n(local — no HTTP)"]
    end

    subgraph Execution ["▶️ malloy_executor_tool.py"]
        Translate["Malloy → MySQL\n(LLM translation · llama-3.3-70b)"]
        MySQL[("MySQL\nfmcg_database")]
    end

    subgraph Infra ["📡 Infrastructure"]
        Phoenix["Arize Phoenix\nObservability UI\n(port 6006)"]
        Neo4j[("Neo4j\nGraph DB\n(table relationships)")]
        MalloyModel["models/fmcg.malloy\n(semantic schema:\ntotal_revenue, etc.)"]
        Env[".env / config.py\n(API keys · DB creds)"]
    end

    %% User → Frontend
    User -->|"types query"| UI
    UI --> Hook
    Hook --> SSEService
    SSEService -->|"POST /chat"| FastAPI

    %% Backend SSE loop
    FastAPI --> ThinkingHandler
    FastAPI --> Agent
    ThinkingHandler -->|"SSE events (thinking)"| SSEService
    Agent -->|"final answer (content)"| FastAPI

    %% Agent → Tools
    Agent -->|"1. invoke"| T1
    Agent -->|"2. invoke"| T2
    Agent -->|"3. invoke"| T3
    Agent -->|"4. invoke"| T4

    %% Tools → MCP
    T1 --> IntentEP
    T2 --> SearchEP
    T3 --> MalloyGenEP

    %% MCP internal
    SearchEP --> BM25
    SearchEP --> FAISS
    SearchEP --> N2V
    BM25 & FAISS & N2V --> RRF

    %% Execution
    T4 --> Translate
    Translate -->|"SQL query"| MySQL
    MySQL -->|"JSON rows"| Translate

    %% Infra connections
    N2V -.->|"MATCH queries"| Neo4j
    MalloyGenEP -.->|"schema reference"| MalloyModel
    Translate -.->|"schema reference"| MalloyModel
    Backend -.->|"OTLP traces"| Phoenix
    MCP -.->|"OTLP traces"| Phoenix
    Env -.-> Backend
    Env -.-> MCP
```

